{
  // Aider agent running in an agentcontainer.
  "image": "python:3.12-bookworm",
  "agent": {
    "capabilities": {
      "network": {
        "egress": [
          { "host": "api.anthropic.com", "port": 443 },
          { "host": "pypi.org", "port": 443 },
          { "host": "files.pythonhosted.org", "port": 443 }
        ]
      },
      "shell": {
        "commands": ["aider", "python", "pip", "git"]
      },
      "filesystem": {
        "read": ["/workspace"],
        "write": ["/workspace"]
      }
    },
    "secrets": {
      "ANTHROPIC_API_KEY": {
        "provider": "env://ANTHROPIC_API_KEY"
      }
    }
  },
  "postCreateCommand": "pip install aider-chat"
}
