{
  // Goose (Block) agent running in an agentcontainer.
  "image": "ubuntu:24.04",
  "agent": {
    "capabilities": {
      "network": {
        "egress": [
          { "host": "api.anthropic.com", "port": 443 }
        ]
      },
      "shell": {
        "commands": ["goose", "git"]
      },
      "filesystem": {
        "read": ["/workspace"],
        "write": ["/workspace"]
      }
    },
    "secrets": {
      "ANTHROPIC_API_KEY": {
        "provider": "env://ANTHROPIC_API_KEY"
      }
    }
  },
  "postCreateCommand": "curl -fsSL https://github.com/block/goose/releases/latest/download/install.sh | bash"
}
